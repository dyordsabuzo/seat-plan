rules_version = '2';
service cloud.firestore {
  // Example rules for `clubs` and nested `clubs/{clubId}/regattas` and top-level `regattas`
  // These rules require that the authenticated user is listed in a document's `owners` array.

  match /databases/{database}/documents {
    // Clubs documents: require membership in owners to read/write
    match /clubs/{clubId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.owners;
      allow create: if request.auth != null && request.resource.data.owners is list && request.auth.uid in request.resource.data.owners;
      allow update, delete: if request.auth != null && request.auth.uid in resource.data.owners;

      // Nested regattas under clubs/{clubId}/regattas/{regattaId}
      match /regattas/{regattaId} {
        // Allow reads/writes only when the user is an owner of the parent club
        allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/clubs/$(clubId)).data.owners;
      }
    }

    // Optional top-level regattas collection compatibility
    match /regattas/{regattaId} {
      // For top-level docs, require the user be in the document owners array
      allow read: if request.auth != null && request.auth.uid in resource.data.owners;
      allow create: if request.auth != null && request.resource.data.owners is list && request.auth.uid in request.resource.data.owners;
      allow update, delete: if request.auth != null && request.auth.uid in resource.data.owners;
    }
  }
}
